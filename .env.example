# Copy these names to Elastic Beanstalk environment properties. Never commit values.
FRONTEND_URL=https://your-cloudfront-domain.example
CORS_ALLOWED_ORIGINS=https://your-cloudfront-domain.example
COOKIE_SAME_SITE=None
COOKIE_SECURE=true

# These must exactly match the provider console callback entries.
GOOGLE_OAUTH2_REDIRECT_URI=https://your-public-backend.example/login/oauth2/code/google
GITHUB_OAUTH2_REDIRECT_URI=https://your-public-backend.example/login/oauth2/code/github
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Payment gateway values are server-only.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional Gemini grounded web research controls. The existing Gemini API key is reused.
GEMINI_WEB_RESEARCH_ENABLED=true
GEMINI_WEB_RESEARCH_MODEL=
GEMINI_WEB_RESEARCH_TIMEOUT_SECONDS=15
GEMINI_WEB_RESEARCH_CACHE_MINUTES=15
